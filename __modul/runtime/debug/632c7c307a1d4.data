    LEFT JOIN pg_type td ON t.typndims > 0 AND t.typbasetype > 0 AND tb.typelem = td.oid
    LEFT JOIN pg_namespace d ON d.oid = c.relnamespace
    LEFT JOIN pg_constraint ct ON ct.conrelid = c.oid AND ct.contype = 'p'
WHERE
    a.attnum > 0 AND t.typname != '' AND NOT a.attisdropped
    AND c.relname = 'content'
    AND d.nspname = 'public'
ORDER BY
    a.attnum;";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1663859760.647048;i:4;a:2:{i:0;a:5:{s:4:"file";s:71:"C:\laragon\www\cms-yii-php-8.1\__modul\models\content\ContentSearch.php";s:4:"line";i:51;s:8:"function";s:4:"load";s:5:"class";s:14:"yii\base\Model";s:4:"type";s:2:"->";}i:1;a:5:{s:4:"file";s:72:"C:\laragon\www\cms-yii-php-8.1\__modul\controllers\ContentController.php";s:4:"line";i:50;s:8:"function";s:6:"search";s:5:"class";s:32:"app\models\content\ContentSearch";s:4:"type";s:2:"->";}}i:5;i:7091336;}i:34;a:6:{i:0;s:875:"select
