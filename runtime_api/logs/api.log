                SELECT 
                    t.kode_trans,
                    t.tgl_kejadian,
                    m.nama_bencana as jenis_bencana,
                    l.latitude,
                    l.longitude,
                    l.nama_desa,
                    l.kecamatan,
                    (COALESCE(t.jml_meninggal, 0) + COALESCE(t.jml_lkbrt, 0) + COALESCE(t.jml_lkringan, 0) + COALESCE(t.jml_hilang, 0)) as total_korban
                FROM public.transaksi_laporan t
                INNER JOIN public.laporan_kejadian_lokasi l ON l.id_laporan = t.kode_trans
                LEFT JOIN public.master_dt_bencana m ON CAST(m.id_master_dt_bencana AS TEXT) = t.kd_jenis_bencana
                 WHERE l.latitude IS NOT NULL AND l.latitude != '' AND l.longitude IS NOT NULL AND l.longitude != '' AND (UPPER(t.prov_single) = 'GORONTALO' OR UPPER(t.prov_single) LIKE '%GORONTALO%')
