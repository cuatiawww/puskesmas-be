                SELECT 
                    COUNT(*) as total_bencana,
                    SUM(COALESCE(jml_meninggal, 0)) as total_meninggal,
                    SUM(COALESCE(jml_lkbrt, 0) + COALESCE(jml_lkringan, 0)) as total_luka,
                    SUM(COALESCE(jml_hilang, 0)) as total_hilang,
