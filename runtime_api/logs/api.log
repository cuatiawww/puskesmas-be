2026-06-23 08:21:13 [127.0.0.1][-][-][info][yii\db\Command::query] 
                SELECT 
                    w.prov_name as nama,
                    COUNT(t.kode_trans) as jumlah
                FROM public.transaksi_laporan t
                LEFT JOIN (
                    SELECT prov_id, prov_name 
                    FROM public.wilyah_indonesia 
                    GROUP BY prov_id, prov_name
                ) w ON CAST(w.prov_id AS TEXT) = t.prov_single
                 WHERE (UPPER(t.prov_single) = 'GORONTALO' OR UPPER(t.prov_single) LIKE '%GORONTALO%')
                GROUP BY w.prov_name
                ORDER BY jumlah DESC
            
